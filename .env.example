# Copy to .env and fill in. Non-secret values are baked into the deployment's
# env_vars at deploy time; secrets are configured separately (see README).

# Target repository the agents operate on (owner/name). REQUIRED.
FLYTE_AGENT_REPO=your-org/your-sandbox-repo

# Model id passed to litellm (routes to Anthropic when ANTHROPIC_API_KEY is set).
FLYTE_AGENT_MODEL=claude-sonnet-4-5

# Max output tokens per LLM call. Must be generous: the builder stages full file
# contents, and litellm otherwise defaults to only 4096. Clamped to the model max.
FLYTE_AGENT_MAX_TOKENS=32000

# How many build->verify attempts the issue builder gets to satisfy the verifier
# (its feedback + the prior solution are fed back on each retry).
FLYTE_AGENT_MAX_TRIES=3

# Identifier the agent uses when claiming dibs (namespaces claims per deployment).
FLYTE_AGENT_ID=flyte-agent-loop

# How long a dibs claim is honored before it is considered stale (minutes).
FLYTE_AGENT_DIBS_TTL_MINUTES=30

# Shared MemoryStore key used by all three pipelines.
FLYTE_AGENT_MEMORY_KEY=agent-loop-shared

# --- Secrets (do NOT commit real values; inject via Flyte/Union secrets) ------
# GITHUB_TOKEN=github_pat_...     # fine-grained PAT: Contents/PRs/Issues/Discussions
#                                 # = Read+write. Provided by the `github-token` secret.
#                                 # See README "Create a GitHub token".
# ANTHROPIC_API_KEY=sk-ant-...    # provided by the `anthropic-api-key` secret
